{
  "name": "@cdm-pickleball/db",
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./*": {
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "bun --env-file=../../apps/server/.env run scripts/run-migrations.ts",
    "db:stamp-pickleball-migrations": "bun --env-file=../../apps/server/.env run scripts/stamp-pickleball-migrations.ts",
    "db:baseline-migrations": "bun --env-file=../../apps/server/.env run scripts/baseline-drizzle-migrations.ts",
    "db:seed:reservation-manager": "bun --env-file=../../apps/server/.env run scripts/seed-first-reservation-manager.ts",
    "db:seed:schedule-demo": "bun --env-file=../../apps/server/.env run scripts/seed-schedule-demo-data.ts"
  },
  "dependencies": {
    "@cdm-pickleball/env": "workspace:*",
    "dotenv": "catalog:",
    "drizzle-orm": "^0.45.1",
    "pg": "^8.17.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cdm-pickleball/config": "workspace:*",
    "@types/pg": "^8.16.0",
    "drizzle-kit": "^0.31.8",
    "typescript": "^6"
  }
}
