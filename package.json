{
  "name": "cdm-pickleball",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "@types/bun": "^1.3.4",
      "hono": "^4.8.2",
      "@trpc/server": "^11.16.0",
      "better-auth": "1.6.9",
      "next-themes": "^0.4.6",
      "@trpc/tanstack-react-query": "^11.16.0",
      "@trpc/client": "^11.16.0",
      "@tanstack/react-query": "^5.90.12",
      "@tanstack/react-form": "^1.28.0",
      "@types/react-dom": "^19.2.3",
      "@better-auth/expo": "1.6.9"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @cdm-pickleball/db db:push",
    "db:studio": "turbo -F @cdm-pickleball/db db:studio",
    "db:generate": "turbo -F @cdm-pickleball/db db:generate",
    "db:migrate": "turbo -F @cdm-pickleball/db db:migrate"
  },
  "dependencies": {
    "@cdm-pickleball/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@cdm-pickleball/config": "workspace:*",
    "@types/bun": "catalog:",
    "turbo": "^2.8.12",
    "typescript": "^6"
  },
  "packageManager": "bun@1.3.2"
}
